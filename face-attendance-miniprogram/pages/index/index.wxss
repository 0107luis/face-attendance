.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.user-info {
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.welcome {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.department {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.login-form {
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  line-height: 80rpx;
}

.link {
  display: block;
  text-align: center;
  color: #1890ff;
  margin-top: 30rpx;
  font-size: 28rpx;
}

.menu {
  display: flex;
  flex-wrap: wrap;
  margin-top: 30rpx;
}

.menu-item {
  width: 45%;
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  margin: 0 2.5% 20rpx;
  text-align: center;
}

.menu-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.menu-text {
  display: block;
  font-size: 28rpx;
  color: #333;
}
