<view class="container">
  <view class="header">
    <text class="title">刷脸考勤</text>
  </view>

  <view class="status-card">
    <view class="status-item">
      <text class="label">签到状态</text>
      <text class="value {{hasCheckedIn ? 'success' : ''}}">{{hasCheckedIn ? '已签到' : '未签到'}}</text>
    </view>
    <view class="status-item">
      <text class="label">签退状态</text>
      <text class="value {{hasCheckedOut ? 'success' : ''}}">{{hasCheckedOut ? '已签退' : '未签退'}}</text>
    </view>
  </view>

  <button class="btn-checkin" bindtap="handleCheckIn" disabled="{{hasCheckedIn}}">
    {{hasCheckedIn ? '已签到' : '签到'}}
  </button>

  <button class="btn-checkout" bindtap="handleCheckOut" disabled="{{hasCheckedOut || !hasCheckedIn}}">
    {{hasCheckedOut ? '已签退' : '签退'}}
  </button>
</view>
