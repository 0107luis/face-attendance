<view class="container">
  <view class="header">
    <text class="title">人脸考勤系统</text>
    <text class="subtitle">Face Recognition Attendance</text>
  </view>

  <view class="user-info" wx:if="{{isLogged}}">
    <text class="welcome">欢迎，{{realName}}</text>
    <text class="department">{{department}}</text>
  </view>

  <view class="login-form" wx:else>
    <input class="input" placeholder="用户名" bindinput="onUsernameInput"/>
    <input class="input" placeholder="密码" password bindinput="onPasswordInput"/>
    <button class="btn-primary" bindtap="handleLogin">登录</button>
    <navigator url="/pages/register/register" class="link">没有账号？点击注册</navigator>
  </view>

  <view class="menu" wx:if="{{isLogged}}">
    <view class="menu-item" bindtap="navigateToCheckin">
      <text class="menu-icon">📷</text>
      <text class="menu-text">刷脸考勤</text>
    </view>
    <view class="menu-item" bindtap="navigateToRecord">
      <text class="menu-icon">📋</text>
      <text class="menu-text">考勤记录</text>
    </view>
  </view>
</view>
